{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": "src",
    "outDir": "out/types/preload",
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "paths": {
      "@shared/*": ["./src/shared/*"]
    }
  },
  "references": [{ "path": "./tsconfig.shared.json" }],
  "include": ["src/preload/**/*.ts"]
}
